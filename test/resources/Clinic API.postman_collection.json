  "item": [
    {
      "name": "0. Authentication",
      "item": [
        {
          "name": "POST login clinic manager",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test(\"Response time is acceptable\", function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(3000);",
                  "});",
                  "var jsonData = pm.response.json();",
                  "pm.test(\"Login successful\", function () {",
                  "    pm.expect(jsonData.success).to.be.true;",
                  "    pm.expect(jsonData.data).to.have.property('accessToken');",
                  "});",
                  "if(jsonData.data) {",
                  "    if(jsonData.data.accessToken) pm.collectionVariables.set(\"token\", jsonData.data.accessToken);",
                  "    if(jsonData.data.clinicId) pm.collectionVariables.set(\"clinicId\", jsonData.data.clinicId);",
                  "    console.log(\"Auto-saved Token and Clinic ID (\" + jsonData.data.clinicId + \") to variables!\");",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"tringhi@clinic.com\",\n  \"password\": \"Denyeubama1\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "login"
              ]
            }
          },
          "response": []
        }
      ]
    },
